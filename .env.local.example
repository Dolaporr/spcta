# SMTP Configuration — fill these in before deploying
# Option A: Gmail (create an App Password at myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-app-password

# Option B: Resend (https://resend.com — free tier available)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# CONTACT_FROM_EMAIL=hello@your-verified-domain.com

# HubSpot CRM (recommended free CRM)
# Create a private app in HubSpot and paste the access token below
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
